<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Books</title>
    </head>
    <body>
        <%- include('../partials/header') %>
        <ul>
            <% files.forEach(file => { %>
                <li>
                    <a href="<%= baseUrl %>/<%= file.name %>"><%= file.name %></a>
                </li>
            <% }) %>
        </ul>
    </body>
</html>
